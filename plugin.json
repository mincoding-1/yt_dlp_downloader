{
    "name": "yt_dlp_downloader",
    "version": "1.3.0",
    "entrypoint": "main.py",
    "timeout": 3600,
    "capabilities": ["process_exec", "file_write", "idempotent"],
    "required_binaries": ["yt-dlp", "ffmpeg"],
    "rlimits": {
        "RLIMIT_CPU": [3600, 3600],
        "RLIMIT_AS": [2147483648, 2147483648],
        "RLIMIT_FSIZE": [53687091200, 53687091200],
        "RLIMIT_NOFILE": [256, 256]
    },
    "input_schema": {
        "type": "object",
        "required": ["url"],
        "properties": {
            "url": {
                "type": "string",
                "description": "단일 비디오 URL (YouTube, Vimeo 등)"
            },
            "collection": {
                "type": "string",
                "description": "고정 저장 collection. 허용값: plex, shorts, custom"
            },
            "relative_path": {
                "type": "string",
                "description": "collection 아래 상대 저장 경로"
            },
            "output_template": {
                "type": "string",
                "description": "yt-dlp 파일명 템플릿. %(id)s 필수. Plex용으로 %(channel_id)s, %(playlist_id)s 사용 가능"
            },
            "timeout": {
                "type": "integer",
                "description": "다운로드 제한 시간(초, 최대 3600)"
            },
            "metadata_only": {
                "type": "boolean",
                "description": "다운로드하지 않고 메타데이터만 조회"
            },
            "allow_playlist": {
                "type": "boolean",
                "description": "playlist 다운로드 허용"
            },
            "metadata_limit": {
                "type": "integer",
                "description": "메타데이터 조회 시 playlist/channel 항목 최대 개수"
            },
            "format_preset": {
                "type": "string",
                "description": "best, 1080p, 720p, 480p, audio, custom"
            },
            "format_selector": {
                "type": "string",
                "description": "format_preset=custom일 때 사용할 yt-dlp format selector"
            },
            "download_mode": {
                "type": "string",
                "description": "video 또는 audio"
            },
            "audio_format": {
                "type": "string",
                "description": "source, mp3, m4a, opus, flac, wav"
            },
            "selected_entries": {
                "type": "array",
                "description": "playlist/channel에서 다운로드할 1-based 항목 index 목록"
            },
            "archive_mode": {
                "type": "string",
                "description": "disabled, auto, custom"
            },
            "archive_id": {
                "type": "string",
                "description": "archive_mode=custom일 때 사용할 archive id"
            },
            "dry_run": {
                "type": "boolean",
                "description": "다운로드하지 않고 archive 기준 다운로드/스킵 예상 결과만 반환"
            },
            "schedule_id": {
                "type": "string",
                "description": "스케줄 실행 통계 연결용 schedule id"
            }
        }
    },
    "example_payload": {
        "url": "https://media.w3.org/2010/05/sintel/trailer.mp4",
        "collection": "custom",
        "relative_path": "yt_dlp_downloader",
        "output_template": "%(uploader)s [%(channel_id)s]/%(playlist_index)s - %(title).200B [%(id)s].%(ext)s",
        "archive_mode": "disabled",
        "format_preset": "best",
        "download_mode": "video"
    }
}
