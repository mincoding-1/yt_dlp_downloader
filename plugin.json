{
    "name": "yt_dlp_downloader",
    "version": "1.0.0",
    "entrypoint": "main.py",
    "timeout": 7200,
    "capabilities": ["process_exec", "file_write", "idempotent"],
    "requires_binaries": ["yt-dlp"],
    "input_schema": {
        "type": "object",
        "required": ["url"],
        "properties": {
            "url": {
                "type": "string",
                "description": "단일 비디오 URL (YouTube, Vimeo 등)"
            },
            "output_path": {
                "type": "string",
                "description": "저장 경로"
            }
        }
    },
    "example_payload": {
        "url": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
        "output_path": "/mnt/md0/동영상/유튜브/유튜브_강의"
    }
}